generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Provider {
  GOOGLE
  MANUAL
}

enum ArticleVisibility {
  CUSTOM
  PUBLIC
}

enum PermissionRole {
  NONE
  VIEW
  EDIT
}

enum ProjectVisibility {
  PUBLIC
  RESTRICTED
}

enum ProjectPermissionRole {
  VIEW
  EDIT
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  provider           Provider
  passwordHash       String?
  avatarUrl          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sessions           Session[]
  permissions        Permission[]
  articles           Article[]           @relation("ArticleAuthor")
  ownedProjects      Project[]           @relation("ProjectOwner")
  projectPermissions ProjectPermission[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id          String            @id @default(cuid())
  name        String
  description String?
  detail      String?
  imageUrl    String?
  visibility  ProjectVisibility @default(PUBLIC)
  authorId    String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  author      User              @relation("ProjectOwner", fields: [authorId], references: [id])
  topics      Topic[]
  articles    Article[]
  permissions ProjectPermission[]

  @@index([authorId])
}

model Topic {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  articles    Article[]

  @@index([projectId])
}

model ProjectPermission {
  id        String @id @default(cuid())
  projectId String
  userId    String
  role      ProjectPermissionRole @default(VIEW)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Article {
  id          String            @id @default(cuid())
  title       String
  content     Json
  layout      String            @default("document")
  visibility  ArticleVisibility @default(CUSTOM)
  parentId    String?
  projectId   String?
  topicId     String?
  authorId    String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  author      User              @relation("ArticleAuthor", fields: [authorId], references: [id])
  parent      Article?          @relation("ArticleTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Article[]         @relation("ArticleTree")
  permissions Permission[]
  project     Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  topic       Topic?            @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([parentId])
  @@index([authorId])
  @@index([projectId])
  @@index([topicId])
}

model Permission {
  id        String         @id @default(cuid())
  userId    String
  articleId String
  role      PermissionRole
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article        @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
}
